{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Dial": {
    "BaseUrl": "https://dialx.ai/api/v1",
    "ApiVersion": "2024-10-21",
    "DefaultModel": "gpt-4",
    "EmbeddingModel": "text-embedding-3-small",
    "EmbeddingDeploymentName": "text-embedding-3-small",
    "CachePolicy": "availability-priority",
    "ApiKeyEnvironmentVariable": "DIAL_API_KEY",
    "ApiKey": ""
  },
  "Knowledge": {
    "DocumentsPath": "data/knowledge",
    "EmbeddingCachePath": "backend/src/GardenBuddy.Api/knowledge-embeddings-cache.json",
    "ChunkSize": 800,
    "ChunkOverlap": 150
  }
}
