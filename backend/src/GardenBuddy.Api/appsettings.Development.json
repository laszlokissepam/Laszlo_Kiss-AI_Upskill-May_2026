{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=data/products/gardenbuddy.dev.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Dial": {
