    "ApiVersion": "2025-04-01-preview",
    "DefaultModel": "gpt-4",
    "EmbeddingModel": "text-embedding-3-small-1",
    "EmbeddingDeploymentName": "text-embedding-3-small-1",
    "CachePolicy": "availability-priority",
    "ApiKeyEnvironmentVariable": "DIAL_API_KEY",
    "ApiKey": ""
  },
  "Knowledge": {
    "DocumentsPath": "data/knowledge",
    "EmbeddingCachePath": "backend/src/GardenBuddy.Api/knowledge-embeddings-cache.json",
    "ChunkSize": 800,
    "ChunkOverlap": 150
  }
}
